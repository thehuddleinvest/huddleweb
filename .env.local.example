# Copy to .env.local and fill with SCOPED API KEYS (not dashboard passwords).
# .env.local is gitignored. Never commit real values. huddleweb is a PUBLIC repo.
# Set these same variables in Vercel → Project → Settings → Environment Variables.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses row-level security. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (test mode: Developers → API keys) ---
STRIPE_SECRET_KEY=sk_test_xxx
# From the webhook endpoint you create for /api/stripe/webhook
# (or `stripe listen` for local dev). Starts with whsec_.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- App ---
# Local dev: http://localhost:3000  |  Production: https://your-domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Strategist access (comma-separated emails allowed into /strategist) ---
# Production: your strategist's email (e.g. va@thehuddleinvest.com).
# For local testing, use the account you're signed in with.
STRATEGIST_EMAILS=

# --- Telegram (BotFather token; username without the @) ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_BOT_USERNAME=thehuddleinvestbot
# Any random string you choose; also passed to Telegram's setWebhook.
TELEGRAM_WEBHOOK_SECRET=pick-a-long-random-string

# --- Playbook (Alpaca) ---
# 64 hex chars (32 bytes). Encrypts stored Alpaca paper keys at rest.
APP_ENCRYPTION_KEY=64-hex-characters

# --- Scanner ingest ---
# Shared secret the scanner sends as x-scanner-secret to /api/scanner/*.
SCANNER_INGEST_SECRET=pick-a-long-random-string

# Note: tier prices come from lib/tiers.ts (created inline at checkout),
# so there are no Stripe Price IDs to manage here.
