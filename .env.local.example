# Copy to .env.local and fill with SCOPED API KEYS (not dashboard passwords).
# .env.local is gitignored. Never commit real values. huddleweb is a PUBLIC repo.

# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Never expose to the browser. Used in route handlers only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (test mode: Developers > API keys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs for each tier (create these in the Stripe dashboard)
STRIPE_PRICE_KICKOFF=price_xxx
STRIPE_PRICE_DRIVE=price_xxx
STRIPE_PRICE_ENDZONE=price_xxx

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
