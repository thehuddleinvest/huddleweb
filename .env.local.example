# Copy to .env.local and fill with SCOPED API KEYS (not dashboard passwords).
# .env.local is gitignored. Never commit real values. huddleweb is a PUBLIC repo.
# Set these same variables in Vercel → Project → Settings → Environment Variables.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses row-level security. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (test mode: Developers → API keys) ---
STRIPE_SECRET_KEY=sk_test_xxx
# From the webhook endpoint you create for /api/stripe/webhook
# (or `stripe listen` for local dev). Starts with whsec_.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- App ---
# Local dev: http://localhost:3000  |  Production: https://your-domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Note: tier prices come from lib/tiers.ts (created inline at checkout),
# so there are no Stripe Price IDs to manage here.
